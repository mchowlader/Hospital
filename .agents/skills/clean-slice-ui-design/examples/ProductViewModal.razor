@namespace Hospital.Client.Pages.Definitions
@using Hospital.Shared.DTOs.Definitions

@if (Show && Product != null)
{
    <div class="modal-backdrop" @onclick="CloseModal"></div>
    <div class="modal-container modal-large">
        <div class="modal-header">
            <h3>Product Details: @Product.Name</h3>
            <button class="btn-close" @onclick="CloseModal">&times;</button>
        </div>
        <div class="modal-body modal-scroll">
            <div class="product-modal-layout">
                <!-- Specs Info & Details -->
                <div class="product-modal-info-col">
                    <div class="view-detail-card">
                        <div class="view-detail-grid">
                            <div class="view-detail-item">
                                <span class="detail-label">Style Code</span>
                                <span class="detail-value style-code-badge">@Product.StyleCode</span>
                            </div>
                            <div class="view-detail-item">
                                <span class="detail-label">Product Name</span>
                                <span class="detail-value text-bold">@Product.Name</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" @onclick="CloseModal">Close</button>
        </div>
    </div>
}
