@namespace Hospital.Client.Pages.DepartmentTerms
@using Hospital.Shared.DTOs.Departments

@if (Show && Term != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>📋 Treatment Term Details</h3>
                <button class="modal-close" @onclick="CloseModal">✕</button>
            </div>
            
            <div class="modal-body">
                @if (IsLoading)
                {
                    <div class="loading-state">
                        <div class="spinner"></div>
                        <p>Loading details...</p>
                    </div>
                }
                else if (Details != null)
                {
                    <div class="view-detail-card">
                        <div class="view-detail-grid">
                            <div class="view-detail-item">
                                <span class="detail-label">Treatment Name</span>
                                <span class="detail-value text-bold">@Details.Name</span>
                            </div>
                            <div class="view-detail-item">
                                <span class="detail-label">Department</span>
                                <span class="detail-value">🏢 @Details.DepartmentName</span>
                            </div>
                            <div class="view-detail-item">
                                <span class="detail-label">Base Cost</span>
                                <span class="detail-value cost-highlight">৳ @Details.BaseCost.ToString("N2")</span>
                            </div>
                            <div class="view-detail-item full-width">
                                <span class="detail-label">Description</span>
                                <span class="detail-value text-muted">
                                    @(string.IsNullOrEmpty(Details.Description) ? "No description provided." : Details.Description)
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Close</button>
                <AuthorizeView Policy="DepartmentTermEdit">
                    <Authorized>
                        <button class="btn btn-primary" @onclick="TriggerEdit">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle;">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                            <span style="display: inline-block; vertical-align: middle;">Edit Term</span>
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
}
