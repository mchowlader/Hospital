@namespace Hospital.Client.Pages.Doctors
@using Hospital.Shared.DTOs.Departments

@if (Show && Doctor != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-box wide" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Edit Doctor</h3>
                <button class="modal-close" @onclick="CloseModal">✕</button>
            </div>
            <EditForm Model="FormModel" OnValidSubmit="SaveDoctor">
                <DataAnnotationsValidator />
                
                @if (!string.IsNullOrEmpty(ModalErrorMessage))
                {
                    <div class="alert alert-danger">
                        <span class="alert-icon">✕</span> @ModalErrorMessage
                    </div>
                }

                <div class="modal-body">
                    <div class="form-row">
                        <div class="form-group">
                            <label>First Name <span class="required">*</span></label>
                            <InputText class="form-control" @bind-Value="FormModel.FirstName" placeholder="First name" />
                            <ValidationMessage For="() => FormModel.FirstName" class="validation-msg" />
                        </div>
                        <div class="form-group">
                            <label>Last Name <span class="required">*</span></label>
                            <InputText class="form-control" @bind-Value="FormModel.LastName" placeholder="Last name" />
                            <ValidationMessage For="() => FormModel.LastName" class="validation-msg" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Email <span class="required">*</span></label>
                            <InputText class="form-control" @bind-Value="FormModel.Email" placeholder="doctor@hospital.com" />
                            <ValidationMessage For="() => FormModel.Email" class="validation-msg" />
                        </div>
                        <div class="form-group">
                            <label>Phone Number <span class="required">*</span></label>
                            <InputText class="form-control" @bind-Value="FormModel.PhoneNumber" placeholder="+880..." />
                            <ValidationMessage For="() => FormModel.PhoneNumber" class="validation-msg" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Specialization <span class="required">*</span></label>
                            <InputText class="form-control" @bind-Value="FormModel.Specialization" placeholder="e.g. Orthodontics, Periodontics..." />
                            <ValidationMessage For="() => FormModel.Specialization" class="validation-msg" />
                        </div>
                        <div class="form-group">
                            <label>Department <span class="required">*</span></label>
                            <InputSelect class="form-control" @bind-Value="FormModel.DepartmentId">
                                <option value="0">Select department...</option>
                                @if (Departments != null)
                                {
                                    @foreach (var dept in Departments)
                                    {
                                        <option value="@dept.Id">@dept.Name</option>
                                    }
                                }
                            </InputSelect>
                            <ValidationMessage For="() => FormModel.DepartmentId" class="validation-msg" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="btn btn-primary" disabled="@IsSaving">
                        @if (IsSaving) 
                        { 
                            <span class="btn-spinner"></span> 
                            <span>Saving...</span> 
                        }
                        else 
                        { 
                            <span>Update Doctor</span> 
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}
