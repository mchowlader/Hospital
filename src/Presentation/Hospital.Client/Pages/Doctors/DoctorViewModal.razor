@namespace Hospital.Client.Pages.Doctors
@using Hospital.Shared.DTOs.Doctors

@if (Show && Doctor != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>👨‍⚕️ Doctor Profile</h3>
                <button class="modal-close" @onclick="CloseModal">✕</button>
            </div>
            
            <div class="modal-body">
                @if (IsLoading)
                {
                    <div class="loading-state">
                        <div class="spinner"></div>
                        <p>Loading details...</p>
                    </div>
                }
                else if (Details != null)
                {
                    <div class="profile-card">
                        <div class="profile-header">
                            <div class="profile-avatar" style="background: @GetAvatarColor(Details.FirstName)">
                                @Details.FirstName[0].ToString().ToUpper()
                            </div>
                            <div class="profile-title-section">
                                <h4 class="profile-name">Dr. @Details.FullName</h4>
                                <span class="badge badge-blue">@Details.Specialization</span>
                            </div>
                        </div>

                        <div class="profile-details-grid">
                            <div class="detail-item">
                                <span class="detail-label">Department</span>
                                <span class="detail-value">@Details.DepartmentName</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Email Address</span>
                                <span class="detail-value">📧 @Details.Email</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Phone Number</span>
                                <span class="detail-value">📞 @Details.PhoneNumber</span>
                            </div>
                            @if (Details.UserId.HasValue)
                            {
                                <div class="detail-item">
                                    <span class="detail-label">System User ID</span>
                                    <span class="detail-value">👤 User #@Details.UserId.Value</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseModal">Close</button>
                <AuthorizeView Policy="DoctorEdit">
                    <Authorized>
                        <button class="btn btn-primary" @onclick="TriggerEdit">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px; display: inline-block; vertical-align: middle;">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                            <span>Edit Doctor</span>
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
}
