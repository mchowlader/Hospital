{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=FarzanasDentalDB;Username=farzana;Password=farzana;Include Error Detail=true"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "Jwt": {
    "Key": "super_secret_key_for_development_hospital_management_123456",
    "Issuer": "Hospital.Api",
    "Audience": "Hospital.Client"
  },
  "AllowedHosts": "*"
}
